{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "tsx server.ts",
    "build": "rm -rf dist && npm run clean:cache && vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist && npm run clean:cache",
    "clean:cache": "rm -rf node_modules/.cache .npm node_modules/.vite",
    "lint": "tsc --noEmit",
    "start": "cross-env NODE_ENV=production tsx server.ts",
    "deploy:rules": "npx firebase-tools deploy --only firestore:aistudio"
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
