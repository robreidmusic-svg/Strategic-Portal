    "@vitejs/plugin-react": "^5.0.4",
    "clsx": "^2.1.1",
    "cross-env": "^10.1.0",
    "d3-force": "^3.0.0",
    "deck.gl": "^9.3.1",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "firebase": "^12.12.0",
    "firebase-admin": "^13.8.0",
    "jszip": "^3.10.1",
    "lucide-react": "^0.546.0",
    "mammoth": "^1.12.0",
    "maplibre-gl": "^5.24.0",
    "motion": "^12.23.24",
    "papaparse": "^5.5.3",
    "pdfjs-dist": "^3.11.174",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-force-graph-2d": "^1.29.1",
